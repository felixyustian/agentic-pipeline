# ─────────────────────────────────────────
#  Agentic Pipeline — Environment Variables
# ─────────────────────────────────────────

# OpenAI API key — required for all LLM and embedding calls
OPENAI_API_KEY=sk-...

# Model names (override defaults in config.ts if needed)
PRIMARY_MODEL=gpt-4o
CHEAP_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Confidence thresholds (optional — defaults match config.ts)
CONFIDENCE_AUTO_APPROVE=0.90
CONFIDENCE_HUMAN_REVIEW=0.65

# HITL webhook — POST target for escalation alerts
HITL_WEBHOOK_URL=https://your-ops-platform.example.com/webhooks/ai-escalation
